@{
ViewData["Title"] = "HockeyDJ Setup";
}

<!DOCTYPE html>
<html>

<head>
    <title>@ViewData["Title"]</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 40px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 2.5em;
            margin: 0;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            background: linear-gradient(45deg, #ff6b35, #f7931e);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #ff6b35;
        }

        .form-control {
            width: 100%;
            padding: 12px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-size: 16px;
            box-sizing: border-box;
        }

        .form-control:focus {
            outline: none;
            border-color: #ff6b35;
            box-shadow: 0 0 10px rgba(255, 107, 53, 0.3);
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        textarea.form-control {
            height: 120px;
            resize: vertical;
        }

        .btn {
            background: linear-gradient(45deg, #28a745, #20c997);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 8px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s ease;
        }

        .btn:hover {
            background: linear-gradient(45deg, #218838, #1ba085);
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: linear-gradient(45deg, #6c757d, #5a6268);
            margin-bottom: 10px;
        }

        .btn-secondary:hover {
            background: linear-gradient(45deg, #545b62, #4e555b);
        }

        .btn-warning {
            background: linear-gradient(45deg, #ffc107, #e0a800);
            color: #212529;
        }

        .btn-warning:hover {
            background: linear-gradient(45deg, #e0a800, #d39e00);
        }

        .btn-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 20px;
        }

        .instructions {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 30px;
            border-left: 4px solid #ff6b35;
        }

        .instructions h3 {
            margin-top: 0;
            color: #ff6b35;
        }

        .instructions ol {
            padding-left: 20px;
        }

        .instructions li {
            margin-bottom: 10px;
            line-height: 1.5;
        }

        .error {
            background: rgba(220, 53, 69, 0.2);
            border: 1px solid #dc3545;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            text-align: center;
        }

        .success {
            background: rgba(40, 167, 69, 0.2);
            border: 1px solid #28a745;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            text-align: center;
            color: #d4edda;
        }

        .code {
            background: rgba(0, 0, 0, 0.3);
            padding: 4px 8px;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
            font-size: 14px;
        }

        .goal-horn-section {
            background: rgba(255, 107, 53, 0.1);
            border: 1px solid rgba(255, 107, 53, 0.3);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 25px;
        }

        .goal-horn-section h4 {
            color: #ff6b35;
            margin-top: 0;
            font-size: 1.3em;
        }

        .config-tools {
            background: rgba(138, 43, 226, 0.1);
            border: 1px solid rgba(138, 43, 226, 0.3);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 25px;
        }

        .config-tools h4 {
            color: #ba55d3;
            margin-top: 0;
            font-size: 1.3em;
        }

        #importFile {
            display: none;
        }

        .file-input-wrapper {
            position: relative;
            overflow: hidden;
            display: inline-block;
            width: 100%;
        }

        .file-input-wrapper input[type=file] {
            position: absolute;
            left: -9999px;
        }

        .file-input-wrapper .file-input-button {
            background: linear-gradient(45deg, #17a2b8, #138496);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 8px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s ease;
            display: block;
            text-align: center;
        }

        .file-input-wrapper .file-input-button:hover {
            background: linear-gradient(45deg, #138496, #0f6674);
            transform: translateY(-2px);
        }

        .selected-file {
            margin-top: 10px;
            padding: 10px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 5px;
            font-size: 14px;
            color: #b8daff;
        }

        .divider {
            border-top: 2px solid rgba(255, 255, 255, 0.2);
            margin: 30px 0;
            position: relative;
        }

        .divider::after {
            content: "OR";
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            padding: 0 15px;
            color: rgba(255, 255, 255, 0.7);
            font-weight: bold;
        }

        /* Sound Upload Styles */
        .sound-upload-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .sound-upload-card {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            padding: 15px;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .sound-upload-card label {
            display: block;
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 1em;
        }

        .upload-controls {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            align-items: center;
        }

        .upload-controls input[type="file"] {
            font-size: 0.8em;
            max-width: 140px;
        }

        .btn-preview, .btn-reset {
            padding: 4px 10px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.8em;
        }

        .btn-preview {
            background: #27ae60;
            color: white;
        }

        .btn-reset {
            background: #e74c3c;
            color: white;
        }

        .upload-status {
            display: block;
            margin-top: 5px;
            font-size: 0.85em;
        }

        .upload-status.success { color: #2ecc71; }
        .upload-status.error { color: #e74c3c; }
        .upload-status.uploading { color: #f39c12; }

        .custom-sound-upload {
            margin: 15px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .custom-sounds-list {
            margin-top: 15px;
        }

        .custom-sound-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 15px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            margin-bottom: 8px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            flex-wrap: wrap;
            gap: 8px;
        }

        .custom-sound-preview {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .custom-sound-preview .sound-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            font-size: 1.2em;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .custom-sound-controls {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .custom-sound-controls .emoji-input {
            width: 45px;
            text-align: center;
            padding: 4px;
            border-radius: 5px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-size: 1em;
        }

        .custom-sound-controls .name-input {
            width: 120px;
            padding: 4px 8px;
            border-radius: 5px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-size: 0.85em;
        }

        .custom-sound-controls select {
            padding: 4px;
            border-radius: 5px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            background: rgba(0, 0, 0, 0.3);
            color: white;
            font-size: 0.85em;
        }

        .btn-delete {
            padding: 4px 8px;
            border: none;
            border-radius: 5px;
            background: #e74c3c;
            color: white;
            cursor: pointer;
            font-size: 0.9em;
        }

        .btn-sound-red { background: radial-gradient(circle, #ff6b6b, #c0392b); }
        .btn-sound-blue { background: radial-gradient(circle, #74b9ff, #0984e3); }
        .btn-sound-gold { background: radial-gradient(circle, #ffeaa7, #fdcb6e); color: #2d3436; }
        .btn-sound-green { background: radial-gradient(circle, #55efc4, #00b894); }
        .btn-sound-purple { background: radial-gradient(circle, #a29bfe, #6c5ce7); }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1>🏒 HockeyDJ Setup</h1>
            <p>Configure your Spotify connection and playlists</p>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
        <div class="error">@ViewBag.Error</div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.Success))
        {
        <div class="success">@ViewBag.Success</div>
        }

        <div class="config-tools">
            <h4>🔧 Configuration Tools</h4>
            <div class="btn-group">
                <button type="button" class="btn btn-warning" onclick="exportConfiguration()">
                    📤 Export Configuration
                </button>
                <div class="file-input-wrapper">
                    <input type="file" id="importFile" accept=".json" onchange="importConfiguration(this)" />
                    <label for="importFile" class="file-input-button">
                        📥 Import Configuration
                    </label>
                </div>
            </div>
            <div id="selectedFileDisplay" class="selected-file" style="display: none;"></div>
            <p style="font-size: 14px; color: rgba(255,255,255,0.7); margin: 10px 0 0 0;">
                💡 Save your configuration to easily restore settings or share with other devices.
            </p>
        </div>

        <div class="divider"></div>

        <div class="instructions">
            <h3>Setup Instructions</h3>
            <ol>
                <li>Go to <a href="https://developer.spotify.com/dashboard" target="_blank"
                        style="color: #ff6b35;">Spotify Developer Dashboard</a></li>
                <li>Create a new app or use an existing one</li>
                <li>Add your redirect URI to the app settings (e.g., <span
                        class="code">https://localhost:7001/Home/SpotifyCallback</span>)</li>
                <li>Copy your Client ID and Client Secret</li>
                <li>
                    Add your sound files to <span class="code">wwwroot/audio/</span>:
                    <ul style="margin-top: 5px;">
                        <li><span class="code">goal-horn.mp3</span> - Goal celebration sound</li>
                        <li><span class="code">mushroom.mp3</span> - Even Strength (Extra Life) sound</li>
                        <li><span class="code">clock.mp3</span> - One Minute Remaining Sound</li>
                    </ul>
                </li>
                <li>Paste your Spotify playlist URLs below</li>
                <li>Make sure you have Spotify Premium (required for playback control)</li>
            </ol>
        </div>

        <form method="post" action="/Home/SaveSpotifyConfig" id="configForm">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="clientId">Spotify Client ID</label>
                <input type="text" id="clientId" name="clientId" class="form-control"
                    placeholder="Your Spotify App Client ID" required />
            </div>

            <div class="form-group">
                <label for="clientSecret">Spotify Client Secret</label>
                <input type="text" id="clientSecret" name="clientSecret" class="form-control"
                    placeholder="Your Spotify App Client Secret" required />
            </div>

            <div class="form-group">
                <label for="redirectUri">Redirect URI</label>
                <input type="url" id="redirectUri" name="redirectUri" class="form-control"
                    placeholder="https://127.0.0.1:7001/Home/SpotifyCallback"
                    value="https://127.0.0.1:7001/Home/SpotifyCallback" required />
            </div>

            <div class="goal-horn-section">
                <h4>🚨 Goal Horn Configuration 🚨</h4>
                <div class="form-group">
                    <label for="goalHornPlaylist">Goal Celebration Playlist URL</label>
                    <input type="url" id="goalHornPlaylist" name="goalHornPlaylist" class="form-control"
                        placeholder="https://open.spotify.com/playlist/your-goal-celebration-playlist" />
                    <small style="color: rgba(255,255,255,0.7); font-size: 14px; margin-top: 5px; display: block;">
                        🎵 This playlist will play victory songs after the goal horn sound. Leave empty to use the first
                        playlist below.
                    </small>
                </div>
                <div class="form-group">
                    <label for="songStartTimestamps">Song Start Timestamps (Player Number:Timestamp, one per line)</label>
                    <textarea id="songStartTimestamps" name="songStartTimestamps" class="form-control"
                        placeholder="4:0:45&#10;7:1:30&#10;9:0:15"
                        style="height: 120px;"></textarea>
                    <small style="color: rgba(255,255,255,0.7); font-size: 14px; margin-top: 5px; display: block;">
                        ⏱️ Format: PlayerNumber:Minutes:Seconds (e.g., "4:1:30" means player 4's song starts at 1 minute 30 seconds).<br>
                        When you select a player number before triggering the goal horn, their song will start at this timestamp. Leave blank to start songs from the beginning.
                    </small>
                </div>
            </div>

            <div class="goal-horn-section">
                <h4>🎩 Hat Trick Celebration 🎩</h4>
                <div class="form-group">
                    <label for="hatTrickSongUrl">Hat Trick Song (Spotify Track URL)</label>
                    <input type="url" id="hatTrickSongUrl" name="hatTrickSongUrl" class="form-control"
                        placeholder="https://open.spotify.com/track/... or spotify:track:..." 
                        value="@ViewBag.HatTrickSongUri" />
                    <small style="color: rgba(255,255,255,0.7); font-size: 14px; margin-top: 5px; display: block;">
                        🎵 Special song to play when any player scores their 3rd goal. Leave blank for normal celebration.
                    </small>
                </div>
                <div class="button-group" style="margin-top: 10px;">
                    <button type="button" onclick="saveHatTrickSong()" class="btn-secondary" 
                        style="background: linear-gradient(135deg, #4CAF50, #45a049); margin-right: 10px;">
                        💾 Save Hat Trick Song
                    </button>
                    <button type="button" onclick="previewHatTrickSong()" class="btn-secondary"
                        style="background: linear-gradient(135deg, #2196F3, #1976D2); margin-right: 10px;">
                        ▶️ Preview
                    </button>
                    <button type="button" onclick="clearHatTrickSong()" class="btn-danger" 
                        style="background: linear-gradient(135deg, #f44336, #d32f2f);">
                        🗑️ Clear
                    </button>
                </div>
                <span id="hatTrickSongStatus" style="display: block; margin-top: 10px; font-weight: bold;"></span>
            </div>

            <div class="goal-horn-section">
                <h4>🏒 Team Roster Configuration 🏒</h4>
                <div class="form-group">
                    <label for="homeTeamName">Home Team Name</label>
                    <input type="text" id="homeTeamName" name="homeTeamName" class="form-control"
                        placeholder="e.g., Lightning, Maple Leafs" />
                </div>
                <div class="form-group">
                    <label for="homeTeamRoster">Home Team Roster (Number:Name, one per line)</label>
                    <textarea id="homeTeamRoster" name="homeTeamRoster" class="form-control"
                        placeholder="1:John Smith&#10;4:Mike Johnson&#10;7:Chris Williams&#10;8:Dave Brown&#10;9:Tom Davis"
                        style="height: 150px;"></textarea>
                    <small style="color: rgba(255,255,255,0.7); font-size: 14px; margin-top: 5px; display: block;">
                        📝 Format: Number:Name (e.g., "7:Connor McDavid")
                    </small>
                </div>
                <div class="form-group">
                    <label for="awayTeamName">Away Team Name</label>
                    <input type="text" id="awayTeamName" name="awayTeamName" class="form-control"
                        placeholder="e.g., Bruins, Rangers" />
                </div>
                <div class="form-group">
                    <label for="awayTeamRoster">Away Team Roster (Number:Name, one per line)</label>
                    <textarea id="awayTeamRoster" name="awayTeamRoster" class="form-control"
                        placeholder="10:Alex Parker&#10;15:Brad Wilson&#10;16:Steve Miller&#10;17:Rob Taylor&#10;18:Joe Anderson"
                        style="height: 150px;"></textarea>
                    <small style="color: rgba(255,255,255,0.7); font-size: 14px; margin-top: 5px; display: block;">
                        📝 Format: Number:Name (e.g., "97:Connor McDavid")
                    </small>
                </div>
            </div>

            <div class="form-group">
                <label for="playlistUrls">Spotify Playlist URLs (up to 10, one per line)</label>
                <textarea id="playlistUrls" name="playlistUrls" class="form-control"
                    placeholder="https://open.spotify.com/playlist/20ObIj4drcpqU4a4ZQPWNU?si=Y8kcaUGxRD6eov5JXfqzmQ&pi=DoFqrvE4RQm6q&#10;https://open.spotify.com/playlist/0Koymm18OCvJcecMXx7TWp?si=ofxcgkaDR8yYRw0wyhQMzw&pi=Hr6_KlG9QbmU0"
                    required></textarea>
                <small style="color: rgba(255,255,255,0.7); font-size: 14px;">
                    Tip: Right-click any Spotify playlist → "Share" → "Copy link" to get the URL
                </small>
            </div>

            <button type="submit" class="btn">Connect to Spotify & Start HockeyDJ</button>
        </form>

        <!-- Sound Upload Section -->
        <div style="margin-top: 40px; padding-top: 30px; border-top: 2px solid rgba(255,255,255,0.2);">
            <h2 style="text-align: center;">🔊 Custom Sound Effects</h2>
            <p style="text-align: center; color: rgba(255,255,255,0.7);">Upload custom audio files (MP3, WAV, OGG - max 10MB)</p>

            <h3>Replace Default Sounds</h3>
            <div class="sound-upload-grid">
                <div class="sound-upload-card">
                    <label>🚨 Goal Horn</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('goalhorn', this)">
                        <button class="btn-preview" onclick="previewSound('goalhorn')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('goalhorn')">↩️</button>
                    </div>
                    <span id="status-goalhorn" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🍄 Mushroom</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('mushroom', this)">
                        <button class="btn-preview" onclick="previewSound('mushroom')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('mushroom')">↩️</button>
                    </div>
                    <span id="status-mushroom" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🕐 Clock</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('clock', this)">
                        <button class="btn-preview" onclick="previewSound('clock')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('clock')">↩️</button>
                    </div>
                    <span id="status-clock" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🎺 Sad Trombone</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('trombone', this)">
                        <button class="btn-preview" onclick="previewSound('trombone')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('trombone')">↩️</button>
                    </div>
                    <span id="status-trombone" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🎹 Charge Organ</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('charge', this)">
                        <button class="btn-preview" onclick="previewSound('charge')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('charge')">↩️</button>
                    </div>
                    <span id="status-charge" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🛎️ Go Hawks Cowbell</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('gohawks', this)">
                        <button class="btn-preview" onclick="previewSound('gohawks')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('gohawks')">↩️</button>
                    </div>
                    <span id="status-gohawks" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🔔 Let's Go Cowbell</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('letsgo-cowbell', this)">
                        <button class="btn-preview" onclick="previewSound('letsgo-cowbell')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('letsgo-cowbell')">↩️</button>
                    </div>
                    <span id="status-letsgo-cowbell" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🎹 Let's Go Organ</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('letsgo-organ', this)">
                        <button class="btn-preview" onclick="previewSound('letsgo-organ')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('letsgo-organ')">↩️</button>
                    </div>
                    <span id="status-letsgo-organ" class="upload-status"></span>
                </div>
                <div class="sound-upload-card">
                    <label>🎩 Hat Trick</label>
                    <div class="upload-controls">
                        <input type="file" accept=".mp3,.wav,.ogg" onchange="uploadSound('hattrick', this)">
                        <button class="btn-preview" onclick="previewSound('hattrick')">▶️</button>
                        <button class="btn-reset" onclick="resetSound('hattrick')">↩️</button>
                    </div>
                    <span id="status-hattrick" class="upload-status"></span>
                </div>
            </div>

            <h3 style="margin-top: 30px;">Add Custom Sound Buttons</h3>
            <p style="color: rgba(255,255,255,0.7); font-size: 0.9em;">
                Upload any audio file to create a new button on the main page.
                <strong>Tip:</strong> Start filename with an emoji for auto-styling (e.g., "🎸 Guitar Riff.mp3")
            </p>

            <div class="custom-sound-upload">
                <input type="file" id="upload-custom-sound" accept=".mp3,.wav,.ogg" onchange="uploadCustomSound(this)">
                <span id="custom-upload-status" class="upload-status"></span>
            </div>

            <div id="custom-sounds-list" class="custom-sounds-list">
            </div>
        </div>
    </div>

    <script>
        function exportConfiguration() {
            // Gather all configuration data
            const config = {
                clientId: document.getElementById('clientId').value,
                clientSecret: document.getElementById('clientSecret').value,
                redirectUri: document.getElementById('redirectUri').value,
                goalHornPlaylist: document.getElementById('goalHornPlaylist').value,
                playlistUrls: document.getElementById('playlistUrls').value,
                homeTeamName: document.getElementById('homeTeamName').value,
                homeTeamRoster: document.getElementById('homeTeamRoster').value,
                awayTeamName: document.getElementById('awayTeamName').value,
                awayTeamRoster: document.getElementById('awayTeamRoster').value,
                songStartTimestamps: document.getElementById('songStartTimestamps').value,
                exportDate: new Date().toISOString(),
                version: "1.3.0"
            };

            // Create and download the file
            const dataStr = JSON.stringify(config, null, 2);
            const dataUri = 'data:application/json;charset=utf-8,' + encodeURIComponent(dataStr);

            const exportFileDefaultName = 'hockeydj-config-' + new Date().toISOString().split('T')[0] + '.json';

            const linkElement = document.createElement('a');
            linkElement.setAttribute('href', dataUri);
            linkElement.setAttribute('download', exportFileDefaultName);
            linkElement.click();
            linkElement.remove();
        }

        function importConfiguration(input) {
            const file = input.files[0];
            if (!file) return;

            // Display selected file name
            const fileDisplay = document.getElementById('selectedFileDisplay');
            fileDisplay.textContent = `Selected: ${file.name}`;
            fileDisplay.style.display = 'block';

            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const configData = e.target.result;

                    // Send to server for processing and validation
                    fetch('/Home/ImportConfiguration', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: JSON.stringify({configData: configData})
                    })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success) {
                                // Populate the form fields with validated data
                                const config = result.config;

                                if (config.clientId) {
                                    document.getElementById('clientId').value = config.clientId;
                                }
                                if (config.clientSecret) {
                                    document.getElementById('clientSecret').value  = config.clientSecret;
                                }
                                if (config.redirectUri) {
                                    document.getElementById('redirectUri').value = config.redirectUri;
                                }
                                if (config.goalHornPlaylist) {
                                    document.getElementById('goalHornPlaylist').value = config.goalHornPlaylist;
                                }
                                if (config.playlistUrls) {
                                    document.getElementById('playlistUrls').value = config.playlistUrls;
                                }
                                if (config.homeTeamName) {
                                    document.getElementById('homeTeamName').value = config.homeTeamName;
                                }
                                if (config.homeTeamRoster) {
                                    document.getElementById('homeTeamRoster').value = config.homeTeamRoster;
                                }
                                if (config.awayTeamName) {
                                    document.getElementById('awayTeamName').value = config.awayTeamName;
                                }
                                if (config.awayTeamRoster) {
                                    document.getElementById('awayTeamRoster').value = config.awayTeamRoster;
                                }
                                if (config.songStartTimestamps) {
                                    document.getElementById('songStartTimestamps').value = config.songStartTimestamps;
                                }
                                if (config.hatTrickSongUri) {
                                    document.getElementById('hatTrickSongUrl').value = config.hatTrickSongUri;
                                }

                                // Show success message
                                showTemporaryMessage('✅ Configuration imported successfully! Please enter your Client Secret to complete the setup.', 'success');

                                // Focus on client secret field since it's not exported for security
                                document.getElementById('clientSecret').focus();
                            } else {
                                throw new Error(result.error || 'Unknown error occurred');
                            }
                        })
                        .catch(error => {
                            showTemporaryMessage('❌ Error importing configuration: ' + error.message, 'error');
                        })
                        .finally(() => {
                            // Clear the file input
                            input.value = '';
                            fileDisplay.style.display = 'none';
                        });

                } catch (error) {
                    showTemporaryMessage('❌ Error reading configuration file: ' + error.message, 'error');
                    input.value = '';
                    fileDisplay.style.display = 'none';
                }
            };
            reader.readAsText(file);
        }

        async function saveHatTrickSong() {
            const songUrl = document.getElementById('hatTrickSongUrl').value.trim();
            const statusEl = document.getElementById('hatTrickSongStatus');

            if (!songUrl) {
                statusEl.textContent = '❌ Please enter a Spotify track URL';
                statusEl.style.color = '#f44336';
                return;
            }

            try {
                const response = await fetch('/Home/SaveHatTrickSong', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ songUrl: songUrl })
                });
                const result = await response.json();

                if (result.success) {
                    statusEl.textContent = '✓ Hat trick song saved successfully!';
                    statusEl.style.color = '#4CAF50';
                } else {
                    statusEl.textContent = '✗ ' + result.error;
                    statusEl.style.color = '#f44336';
                }
            } catch (error) {
                statusEl.textContent = '✗ Failed to save: ' + error.message;
                statusEl.style.color = '#f44336';
            }
        }

        async function clearHatTrickSong() {
            const statusEl = document.getElementById('hatTrickSongStatus');

            try {
                await fetch('/Home/ClearHatTrickSong', { method: 'POST' });
                document.getElementById('hatTrickSongUrl').value = '';
                statusEl.textContent = '✓ Hat trick song cleared';
                statusEl.style.color = '#4CAF50';
            } catch (error) {
                statusEl.textContent = '✗ Failed to clear: ' + error.message;
                statusEl.style.color = '#f44336';
            }
        }

        function previewHatTrickSong() {
            const songUrl = document.getElementById('hatTrickSongUrl').value.trim();
            if (!songUrl) {
                alert('Please enter a Spotify track URL first');
                return;
            }
            // Open the Spotify URL in a new tab for preview
            window.open(songUrl, '_blank');
        }

        function showTemporaryMessage(message, type) {
            // Remove existing temporary messages
            const existingMessages = document.querySelectorAll('.temp-message');
            existingMessages.forEach(msg => msg.remove());

            // Create new message element
            const messageDiv = document.createElement('div');
            messageDiv.className = `${type} temp-message`;
            messageDiv.textContent = message;

            // Insert after the header
            const header = document.querySelector('.header');
            header.insertAdjacentElement('afterend', messageDiv);

            // Remove after 5 seconds
            setTimeout(() => {
                messageDiv.remove();
            }, 5000);
        }

        // Enhance form validation
        document.getElementById('configForm').addEventListener('submit', function (e) {
            const clientId = document.getElementById('clientId').value.trim();
            const clientSecret = document.getElementById('clientSecret').value.trim();
            const redirectUri = document.getElementById('redirectUri').value.trim();
            const playlistUrls = document.getElementById('playlistUrls').value.trim();

            if (!clientId || !clientSecret || !redirectUri || !playlistUrls) {
                e.preventDefault();
                showTemporaryMessage('❌ Please fill in all required fields!', 'error');
                return false;
            }

            // Validate redirect URI format
            try {
                new URL(redirectUri);
            } catch {
                e.preventDefault();
                showTemporaryMessage('❌ Please enter a valid redirect URI!', 'error');
                return false;
            }

            // Validate playlist URLs
            const urls = playlistUrls.split('\n').filter(url => url.trim());
            const invalidUrls = urls.filter(url => {
                try {
                    const urlObj = new URL(url.trim());
                    return !urlObj.hostname.includes('spotify.com');
                } catch {
                    return true;
                }
            });

            if (invalidUrls.length > 0) {
                e.preventDefault();
                showTemporaryMessage('❌ Please ensure all playlist URLs are valid Spotify URLs!', 'error');
                return false;
            }

            if (urls.length > 10) {
                e.preventDefault();
                showTemporaryMessage('❌ Maximum of 10 playlists allowed!', 'error');
                return false;
            }
        });

        // Populate existing roster data if available
        window.addEventListener('DOMContentLoaded', function() {
            const homeTeamName = @Json.Serialize(ViewBag.HomeTeamName ?? "");
            const homeTeamRoster = @Json.Serialize(ViewBag.HomeTeamRoster ?? "");
            const awayTeamName = @Json.Serialize(ViewBag.AwayTeamName ?? "");
            const awayTeamRoster = @Json.Serialize(ViewBag.AwayTeamRoster ?? "");
            const songStartTimestamps = @Json.Serialize(ViewBag.SongStartTimestamps ?? "");

            if (homeTeamName) {
                document.getElementById('homeTeamName').value = homeTeamName;
            }
            if (homeTeamRoster) {
                document.getElementById('homeTeamRoster').value = homeTeamRoster;
            }
            if (awayTeamName) {
                document.getElementById('awayTeamName').value = awayTeamName;
            }
            if (awayTeamRoster) {
                document.getElementById('awayTeamRoster').value = awayTeamRoster;
            }
            if (songStartTimestamps) {
                document.getElementById('songStartTimestamps').value = songStartTimestamps;
            }
        });

        // ==================== Sound Upload Functions ====================

        let customSoundPaths = {};
        const defaultSoundPaths = {
            'goalhorn': '/audio/goal-horn.mp3',
            'mushroom': '/audio/mushroom.mp3',
            'clock': '/audio/clock.mp3',
            'trombone': '/audio/Sad Trombone.mp3',
            'charge': '/audio/ChargeOrgan.wav',
            'gohawks': '/audio/GoHawksGoCowbell.wav',
            'letsgo-cowbell': '/audio/LetsGoCowbell.wav',
            'letsgo-organ': '/audio/LetsGoOrgan.wav',
            'hattrick': '/audio/hat-trick.mp3'
        };

        // Load existing custom sound mappings on page load
        fetch('/Home/GetCustomSounds')
            .then(r => r.json())
            .then(mappings => {
                customSoundPaths = mappings;
                Object.keys(mappings).forEach(type => {
                    const el = document.getElementById(`status-${type}`);
                    if (el) {
                        el.textContent = '✓ Custom sound loaded';
                        el.className = 'upload-status success';
                    }
                });
            })
            .catch(() => {});

        async function uploadSound(soundType, input) {
            const file = input.files[0];
            if (!file) return;

            const statusEl = document.getElementById(`status-${soundType}`);
            statusEl.textContent = 'Uploading...';
            statusEl.className = 'upload-status uploading';

            const formData = new FormData();
            formData.append('file', file);
            formData.append('soundType', soundType);

            try {
                const response = await fetch('/Home/UploadSound', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    statusEl.textContent = '✓ Uploaded';
                    statusEl.className = 'upload-status success';
                    customSoundPaths[soundType] = result.path;
                } else {
                    statusEl.textContent = '✗ ' + result.error;
                    statusEl.className = 'upload-status error';
                }
            } catch (err) {
                statusEl.textContent = '✗ Upload failed';
                statusEl.className = 'upload-status error';
            }
        }

        function previewSound(soundType) {
            const path = customSoundPaths[soundType] || defaultSoundPaths[soundType];
            if (path) {
                const audio = new Audio(path);
                audio.play();
            }
        }

        async function resetSound(soundType) {
            if (!confirm('Reset to default sound?')) return;

            await fetch('/Home/ResetSound', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ soundType })
            });

            delete customSoundPaths[soundType];
            const el = document.getElementById(`status-${soundType}`);
            if (el) {
                el.textContent = 'Using default';
                el.className = 'upload-status';
            }
        }

        async function uploadCustomSound(input) {
            const file = input.files[0];
            if (!file) return;

            const statusEl = document.getElementById('custom-upload-status');
            statusEl.textContent = 'Uploading...';
            statusEl.className = 'upload-status uploading';

            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch('/Home/UploadCustomSound', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    statusEl.textContent = '✓ Button created!';
                    statusEl.className = 'upload-status success';
                    addCustomSoundToList(result.button);
                    input.value = '';
                } else {
                    statusEl.textContent = '✗ ' + result.error;
                    statusEl.className = 'upload-status error';
                }
            } catch (err) {
                statusEl.textContent = '✗ Upload failed';
                statusEl.className = 'upload-status error';
            }
        }

        function addCustomSoundToList(button) {
            const list = document.getElementById('custom-sounds-list');
            const item = document.createElement('div');
            item.className = 'custom-sound-item';
            item.id = `custom-sound-${button.id}`;

            // Preview section
            const previewDiv = document.createElement('div');
            previewDiv.className = 'custom-sound-preview';

            const previewButton = document.createElement('button');
            previewButton.classList.add('sound-btn');
            if (button.colorClass) {
                previewButton.classList.add(button.colorClass);
            }
            previewButton.textContent = button.emoji || '';
            previewButton.addEventListener('click', function () {
                previewCustomSound(button.path);
            });

            const nameSpan = document.createElement('span');
            nameSpan.className = 'custom-sound-name';
            nameSpan.textContent = button.displayName || '';

            previewDiv.appendChild(previewButton);
            previewDiv.appendChild(nameSpan);

            // Controls section
            const controlsDiv = document.createElement('div');
            controlsDiv.className = 'custom-sound-controls';

            const emojiInput = document.createElement('input');
            emojiInput.type = 'text';
            emojiInput.maxLength = 4;
            emojiInput.className = 'emoji-input';
            emojiInput.value = button.emoji || '';
            emojiInput.addEventListener('change', function () {
                updateCustomSound(button.id, emojiInput.value, null, null);
            });

            const nameInput = document.createElement('input');
            nameInput.type = 'text';
            nameInput.className = 'name-input';
            nameInput.value = button.displayName || '';
            nameInput.addEventListener('change', function () {
                updateCustomSound(button.id, null, nameInput.value, null);
            });

            const select = document.createElement('select');
            const colorOptions = [
                { value: 'btn-sound-red', text: '🔴 Red' },
                { value: 'btn-sound-blue', text: '🔵 Blue' },
                { value: 'btn-sound-gold', text: '🟡 Gold' },
                { value: 'btn-sound-green', text: '🟢 Green' },
                { value: 'btn-sound-purple', text: '🟣 Purple' }
            ];

            colorOptions.forEach(function (opt) {
                const optionEl = document.createElement('option');
                optionEl.value = opt.value;
                optionEl.textContent = opt.text;
                if (button.colorClass === opt.value) {
                    optionEl.selected = true;
                }
                select.appendChild(optionEl);
            });

            select.addEventListener('change', function () {
                updateCustomSound(button.id, null, null, select.value);
            });

            const deleteButton = document.createElement('button');
            deleteButton.className = 'btn-delete';
            deleteButton.textContent = '🗑️';
            deleteButton.addEventListener('click', function () {
                deleteCustomSound(button.id);
            });

            controlsDiv.appendChild(emojiInput);
            controlsDiv.appendChild(nameInput);
            controlsDiv.appendChild(select);
            controlsDiv.appendChild(deleteButton);

            item.appendChild(previewDiv);
            item.appendChild(controlsDiv);

            list.appendChild(item);
        }

        function previewCustomSound(path) {
            const audio = new Audio(path);
            audio.play();
        }

        async function updateCustomSound(id, emoji, displayName, colorClass) {
            await fetch('/Home/UpdateCustomSound', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id, emoji, displayName, colorClass })
            });
            loadCustomSoundsList();
        }

        async function deleteCustomSound(id) {
            if (!confirm('Delete this sound button?')) return;

            await fetch('/Home/DeleteCustomSound', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });

            const el = document.getElementById(`custom-sound-${id}`);
            if (el) el.remove();
        }

        async function loadCustomSoundsList() {
            try {
                const response = await fetch('/Home/GetCustomSoundButtons');
                const sounds = await response.json();

                const list = document.getElementById('custom-sounds-list');
                list.innerHTML = '';
                sounds.forEach(button => addCustomSoundToList(button));
            } catch (err) {
                console.warn('Could not load custom sounds list:', err);
            }
        }

        loadCustomSoundsList();
    </script>
</body>

</html>
